# Utilico Reconciliation Agent — environment variables
# Copy to .env and fill in values (never commit .env)

# Controls which mock scenario is loaded by default
# Options: full_cycle_overbill | phantom_consumption | crm_hold_missing | gl_posted_dispute | clean
UTILCO_DEFAULT_SCENARIO=full_cycle_overbill

# DRI identity used in mock approval gate (simulates human-in-the-loop)
UTILCO_DRI_NAME="Jane Smith"
UTILCO_DRI_EMAIL="jane.smith@utilico.com"

# Audit log output path (relative to project root)
UTILCO_AUDIT_LOG_PATH=audit_logs/

# Conflict detection timeout threshold in seconds (NFR-01 requires < 15s)
UTILCO_CONFLICT_TIMEOUT_SEC=15
