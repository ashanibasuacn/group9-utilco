# Copy to .env and fill in. .env is gitignored.

# LLM provider: "bedrock" (AWS) or "anthropic" (direct API)
LLM_PROVIDER=bedrock

# --- AWS Bedrock (when LLM_PROVIDER=bedrock) ---
# In ap-south-1, use an inference-profile model ID (apac.* prefix).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
BEDROCK_MODEL_ID=apac.anthropic.claude-sonnet-4-20250514-v1:0

# --- Direct Anthropic API (when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=

DATABASE_NAME=utilico_mock
